# IAS Worklytics Production Environment Variables

# Environment
ENVIRONMENT=production

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Frontend Settings (will be set by EasyPanel)
FRONTEND_URL=https://ias-worklytics.yourdomain.com

# Database Settings (EasyPanel MySQL)
DATABASE_URL=mysql+pymysql://Admin:Admin123@website_ias-worklytics-db:3306/ias-worklytics-db