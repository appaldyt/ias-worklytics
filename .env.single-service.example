# IAS Worklytics - Single Service Environment Variables - TEMPLATE

# Backend Configuration
ENVIRONMENT=production
DATABASE_URL=mysql+pymysql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DEBUG=False
API_HOST=127.0.0.1
API_PORT=8000

# Frontend Configuration  
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_URL=https://your-domain.com

# CORS Configuration
FRONTEND_URL=https://your-domain.com

# Example for EasyPanel:
# DATABASE_URL=mysql+pymysql://Admin:PASSWORD@website_ias-worklytics-db:3306/ias-worklytics-db
